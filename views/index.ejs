<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Message Board</title>
    <link rel="stylesheet" href="/styles/root.css" />
    <link rel="stylesheet" href="/styles/nav.css" />
    <link rel="stylesheet" href="/styles/messages.css" />

    <script src="/utils/deleteConfirmationModal.js" defer></script>
  </head>
  <body>
    <%- include("partials/nav") %>
    <main>
      
      <% if (locals.messages.length > 0) { %>
        <section id="messages-section">
          <div id="messages-header">
            <h2>Messages</h2>
            
            <% if (locals.user) { %>
              <a href="/message" class="new-message"> + New Message</a>
            <% } %>
          </div>

          <ul id="messages">
            <% messages.forEach((message) => { %>
              <li>
                <article class="message">
                  <h3><%= message.title %></h3>
                  <p class="message-text"><%= message.message %></p>

                  <div class="message-info">

                    <%# Show message info only to logged in users who are a member or admin %>
                    <% if (locals.user && (user.member || user.admin)) { %>
                      <p><span class="info-header">User: </span><%= message.full_name %> </p>
                      <p><span class="info-header">Posted: </span><%= message.timestamp %></p>

                      <%# If user is an admin show the delete message button %>
                      <% if (user.admin) { %>
                      <button class="modal-btn open-modal" data-message-id="<%= message.message_id %>" aria-label="Delete message: <%= message.title %>">X</button>
                    <% } %>

                    <% } else {%>
                      <p>Sent By: Anonymous</p>
                      <p>Posted: Unknown</p>
                    <% } %>
                  </div>
                </article>
              </li>
          <% }) %>
          </ul>
        </section>
      <% } else { %>
        <section id="no-messages">
          <p>No messages have been posted.</p>
          <% if (locals.user) { %>
              <a href="/message" class="new-message"> + New Message</a>
          <% } %>
        </section>
      <% } %>
    </main>
    <%# Delete confirmation modal %>
      <dialog id="delete-modal">
        <h2>Delete Message</h2>
        <button class="modal-btn" id="close-delete-modal" aria-label="Close delete confirmation">X</button>

        <small id="confirm-text">Are you sure?</small>

        <form action="/message/delete" method="POST">
          <input type="hidden" id="message-id" name="messageId">
          <button type="submit" id="delete-message-btn">Delete</button>
        </form>

      </dialog>

  </body>
</html>
